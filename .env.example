# Copy this file to .env.local and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Supabase --------------------------------------------------------------------
# Phase 0: anonymous-key only — no service-role secrets in client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog ---------------------------------------------------------------------
# Cloud free tier: https://posthog.com (project key, not personal API key).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry ----------------------------------------------------------------------
# DSN is safe to ship to client; rate-limited per project.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# Build metadata --------------------------------------------------------------
# Cloudflare Pages auto-injects CF_PAGES_COMMIT_SHA; we read it in CI.
VITE_BUILD_SHA=local-dev
